generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NEXTAUTH REQUIRED MODELS
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom relations
  customer      Customer?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// SHIPPING WALLET SYSTEM MODELS
// ==========================================

model Customer {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  zohoCrmAccountId       String?  @unique
  zohoInventoryContactId String?  @unique
  companyName            String
  brandSkuPrefix         String?  @unique
  
  billingProfile         BillingProfile?
  walletLedger           ShippingWalletLedger?
  chargeEvents           ShippingChargeEvent[]
  paymentEvents          PaymentEvent[]

  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model BillingProfile {
  id                   String   @id @default(cuid())
  customerId           String   @unique
  billingMode          String   @default("wallet") // "wallet" | "weekly_autodebit"
  creditCap            Float    @default(0.0)
  autoReplenishEnabled Boolean  @default(false)
  fulfillmentHoldStatus Boolean @default(false)
  pendingTopUpInvoiceId String?  // Blocks new top-ups until this invoice is paid

  customer             Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ShippingWalletLedger {
  id          String   @id @default(cuid())
  customerId  String   @unique
  balance     Float    @default(0.0)
  
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
}

model ShippingChargeEvent {
  id               String   @id @default(cuid())
  customerId       String
  veeqoShipmentId  String   @unique
  veeqoOrderId     String
  trackingNumber   String?
  carrier          String?
  serviceLevel     String?
  cost             Float
  billed           Boolean  @default(false)
  paid             Boolean  @default(false)
  
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
}

// Used for idempotency to ensure we don't double charge if polling fails
model VeeqoShipmentsSeen {
  veeqoShipmentId  String   @id
  seenAt           DateTime @default(now())
}

// Audit trail for every payment received from Zoho
model PaymentEvent {
  id                String   @id @default(cuid())
  customerId        String
  zohoPaymentId     String   @unique  // Idempotency key
  amount            Float
  paymentType       String   // "wallet_topup" | "invoice_payment"
  zohoInvoiceNumber String?

  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
}
